<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             x:Class="StickyHomeworks.Controls.WindowMovingDemo"
             mc:Ignorable="d" 
             d:DesignHeight="135"
             d:DesignWidth="240"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Loaded="WindowMovingDemo_OnLoaded"
             IsVisibleChanged="WindowMovingDemo_OnIsVisibleChanged">
    <UserControl.Resources>
        <CubicEase x:Key="EaseSmooth" EasingMode="EaseInOut"/>
        <Storyboard x:Key="Loop" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BorderWindowFrame" Storyboard.TargetProperty="(FrameworkElement.Width)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="60"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.6" Value="60"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="60"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="60"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="90" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="90"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="120" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="120"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="60" EasingFunction="{StaticResource EaseSmooth}"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BorderWindowFrame" Storyboard.TargetProperty="(FrameworkElement.Height)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="75"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.7" Value="75"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="75"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="75"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="95" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="95"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="75" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="75"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="75" EasingFunction="{StaticResource EaseSmooth}"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- 解锁段：轻微透明度脉冲，强调「状态变化」 -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BorderWindowFrame" Storyboard.TargetProperty="(UIElement.Opacity)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.6" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.5" Value="0.92" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.1" Value="1" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.8" Value="0.96" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.5" Value="1" EasingFunction="{StaticResource EaseSmooth}"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BorderWindowFrame" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.7" Value="106.4" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="106.4"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.7" Value="-16" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="-16"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.7" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BorderWindowFrame" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.7" Value="17.6" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="17.6"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.7" Value="28" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="28"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.7" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MousePointer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.7" Value="106.4" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="106.4"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.7" Value="-16" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="-16"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.7" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.4" Value="33" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="33"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="63" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="63"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="93" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="93"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="33" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.7" Value="33"/>
                <EasingDoubleKeyFrame KeyTime="00:00:07.2" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="MousePointer" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                <EasingDoubleKeyFrame KeyTime="00:00:00" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:00.7" Value="17.6" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01" Value="17.6"/>
                <EasingDoubleKeyFrame KeyTime="00:00:01.7" Value="28" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02" Value="28"/>
                <EasingDoubleKeyFrame KeyTime="00:00:02.7" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.4" Value="61" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:03.7" Value="61"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.4" Value="81" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:04.7" Value="81"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.4" Value="61" EasingFunction="{StaticResource EaseSmooth}"/>
                <EasingDoubleKeyFrame KeyTime="00:00:05.7" Value="61"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.4" Value="61"/>
                <EasingDoubleKeyFrame KeyTime="00:00:06.7" Value="61"/>
                <EasingDoubleKeyFrame KeyTime="00:00:07.2" Value="0" EasingFunction="{StaticResource EaseSmooth}"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>
    <Border ClipToBounds="True"
            Background="{DynamicResource MaterialDesignPaper}"
            Width="240"
            Height="135"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.22" Direction="270" Color="#FF000000"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Grid x:Name="ContentGrid">
                <!-- 随 Material 主题变化；浅色下叠加微弱渐变增加层次 -->
                <Rectangle x:Name="RectDesktopBackground"
                           Fill="{DynamicResource MaterialDesignToolBarBackground}"
                           SnapsToDevicePixels="True"/>
                <Rectangle SnapsToDevicePixels="True" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" Opacity="0.55">
                            <GradientStop Offset="0" Color="#18FFFFFF"/>
                            <GradientStop Offset="0.5" Color="#00000000"/>
                            <GradientStop Offset="1" Color="#12000000"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- 任务栏：背景 + 顶部分隔线 + 内容区垂直居中，避免与 11px 底栏错位 -->
                <Grid VerticalAlignment="Bottom" Height="11" SnapsToDevicePixels="True">
                    <Rectangle SnapsToDevicePixels="True">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#E6282830"/>
                                <GradientStop Offset="1" Color="#F01A1C22"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Border VerticalAlignment="Top" Height="1" Background="#40000000" SnapsToDevicePixels="True"/>
                    <Grid Margin="5,0,5,0" VerticalAlignment="Center" Height="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- 开始：与底栏同高，略窄于旧版，更贴 Win 任务栏比例 -->
                        <Rectangle Grid.Column="0"
                                   Width="7"
                                   Height="7"
                                   VerticalAlignment="Center"
                                   Fill="{DynamicResource PrimaryHueMidBrush}"
                                   SnapsToDevicePixels="True"/>
                        <!-- 中间：半透明「占位应用」，与深色底栏同一色系 -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Rectangle Width="5" Height="5" Margin="0,0,3,0" Fill="#52FFFFFF" SnapsToDevicePixels="True"/>
                            <Rectangle Width="5" Height="5" Margin="0,0,3,0" Fill="#52FFFFFF" SnapsToDevicePixels="True"/>
                            <Rectangle Width="5" Height="5" Fill="#52FFFFFF" SnapsToDevicePixels="True"/>
                        </StackPanel>
                        <!-- 右侧：略亮的系统区示意 -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Rectangle Width="5" Height="5" Margin="0,0,2,0" Fill="#7AFFFFFF" SnapsToDevicePixels="True"/>
                            <Rectangle Width="5" Height="5" Margin="0,0,2,0" Fill="#7AFFFFFF" SnapsToDevicePixels="True"/>
                            <Rectangle Width="10" Height="5" Fill="#7AFFFFFF" SnapsToDevicePixels="True"/>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Canvas x:Name="CanvasWindowHost">
                    <Border x:Name="BorderWindowFrame"
                            BorderThickness="1.5"
                            Height="75"
                            Width="60"
                            Canvas.Left="45"
                            Canvas.Top="18"
                            Background="{DynamicResource MaterialDesignPaper}"
                            BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.28" Direction="270" Color="#FF000000"/>
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Border.RenderTransform>
                    </Border>
                    <Border x:Name="MousePointer"
                            Background="Transparent"
                            Canvas.Left="70"
                            Canvas.Top="30"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Path Data="M275.413333 115.925333v716.117334a10.666667 10.666667 0 0 0 1.408 6.144c1.28 1.92 3.413333 3.114667 5.973334 4.181333 1.152 0.512 2.517333 0.896 3.925333 0.896 3.072 0 5.76-1.237333 8.021333-3.413333l170.24-168.917334 103.125334 241.493334a12.032 12.032 0 0 0 15.36 5.845333l84.949333-35.626667a11.989333 11.989333 0 0 0 6.058667-6.4 10.624 10.624 0 0 0-0.128-8.362666l-108.16-253.397334h213.205333c2.474667 0 4.693333-0.256 6.442667-1.450666a12.714667 12.714667 0 0 0 4.181333-5.845334c0.896-2.090667 1.536-4.010667 1.152-5.888-0.426667-1.962667-1.834667-3.584-3.541333-5.248L294.741333 108.202667c-3.157333-3.285333-9.728 0.853333-19.328 7.722666z"
                              Fill="#FFF8F9FB"
                              Stroke="{DynamicResource MaterialDesignBody}"
                              StrokeThickness="0.75"
                              StrokeLineJoin="Round"
                              Stretch="Fill"
                              Width="9.07"
                              Height="14.275"
                              Margin="-1,-1,0,0">
                            <Path.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.35" Direction="270" Color="#FF000000"/>
                            </Path.Effect>
                        </Path>
                    </Border>
                </Canvas>
            </Grid>
        </Grid>
    </Border>
</UserControl>
