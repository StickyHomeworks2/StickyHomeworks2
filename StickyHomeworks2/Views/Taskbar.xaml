<ContextMenu x:Class="StickyHomeworks.Views.Taskbar"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:StickyHomeworks.Views"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:ely="http://github.com/HelloWRC/ElysiaFramework"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="300"  
      FontFamily="{StaticResource HarmonyOsSans}"
      Background="{DynamicResource MaterialDesignPaper}"
      BorderBrush="{DynamicResource MaterialDesignDivider}"
             >

    <ContextMenu.Resources>
        <Style TargetType="MenuItem" BasedOn="{StaticResource MaterialDesignMenuItem}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12 0"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
        </Style>
    </ContextMenu.Resources>
    <MenuItem Header="StickyHomeworks2" IsEnabled="False" FontWeight="Bold">
        <MenuItem.Style>
            <Style TargetType="MenuItem" BasedOn="{StaticResource MaterialDesignMenuItem}">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="12 0"/>
                <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                        <Setter Property="Opacity" Value="1"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </MenuItem.Style>
        <MenuItem.Icon>
            <Image Source="/Assets/AppLogo.png" Width="16" Height="16"/>
        </MenuItem.Icon>
    </MenuItem>
    <MenuItem Header="显示主界面" 
              Click="MenuItemShowMainWindow_OnClick"
              IsCheckable="True">
        <MenuItem.Icon>
            <materialDesign:PackIcon Kind="EyeOutline"/>
        </MenuItem.Icon>
    </MenuItem>
    <Separator/>
    <MenuItem Header="设置…" 
              Click="MenuItemSettings_OnClick">
        <MenuItem.Icon >
            <materialDesign:PackIcon Kind="CogOutline" />
        </MenuItem.Icon>
    </MenuItem>
    <Separator/>
    <MenuItem Header="重启" 
              Click="MenuItemRestartApp_OnClick">
        <MenuItem.Icon>
            <materialDesign:PackIcon Kind="Restart"/>
        </MenuItem.Icon>
    </MenuItem>
    <MenuItem Header="退出" 
              Click="MenuItemExitApp_OnClick">
        <MenuItem.Icon>
            <materialDesign:PackIcon Kind="ExitToApp"/>
        </MenuItem.Icon>
    </MenuItem>
</ContextMenu>
