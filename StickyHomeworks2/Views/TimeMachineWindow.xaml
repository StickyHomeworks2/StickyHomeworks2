<ely:MyWindow x:Class="StickyHomeworks.Views.TimeMachineWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:local="clr-namespace:StickyHomeworks.Views"
                   xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                   xmlns:ely="http://github.com/HelloWRC/ElysiaFramework"
                   mc:Ignorable="d"
                   Icon="/Assets/AppLogo.png"
                   d:DataContext="{d:DesignInstance local:TimeMachineWindow}"
                   Height="650" Width="1200"
                   TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                   Background="{DynamicResource MaterialDesignPaper}"
                   TextElement.FontWeight="Regular"
                   TextElement.FontSize="14"
                   FontFamily="{StaticResource HarmonyOsSans}"
                   Title="时间机器">
    <ely:MyWindow.Resources>
        <local:PreviewPathConverter x:Key="PreviewPathConverter"/>
        <local:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
    </ely:MyWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <materialDesign:ColorZone Grid.Row="0" 
                                  materialDesign:ElevationAssist.Elevation="Dp4"
                                  Mode="PrimaryMid"
                                  Padding="16">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="时间机器" Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="0 0 16 0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button ToolTip="清空所有备份"
                            Padding="0"
                            Style="{StaticResource MaterialDesignToolForegroundButton}"
                            Content="{materialDesign:PackIcon DeleteSweep, Size=24}"
                            Click="ButtonClearAll_OnClick"
                            Margin="0 0 16 0"/>
                    <materialDesign:PopupBox ToolTip="更多选项…"
                                             Margin="0 0 0 0">
                        <StackPanel Margin="16">
                            <TextBlock Text="备份信息" FontWeight="Bold" Margin="0 0 8 0"/>
                            <TextBlock Text="{Binding ViewModel.Backups.Count, StringFormat={}共 {0} 个备份}" FontSize="13"/>
                            <Separator Margin="0 8 0 8"/>
                            <TextBlock Text="提示：每次保存或删除作业时会自动创建备份" 
                                       FontSize="12" 
                                       TextWrapping="Wrap"
                                       MaxWidth="200"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        </StackPanel>
                    </materialDesign:PopupBox>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- 备份列表区域 -->
        <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ViewModel.Backups}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="2"
                                CornerRadius="8"
                                Margin="8"
                                Width="320"
                                Cursor="Hand"
                                MouseLeftButtonDown="BackupItem_OnClick">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Background" Value="{DynamicResource MaterialDesignCardBackground}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.3" Direction="0" ShadowDepth="2"/>
                            </Border.Effect>

                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="180"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 预览图片 -->
                                <Border Grid.Row="0" 
                                        CornerRadius="4" 
                                        ClipToBounds="True"
                                        Background="{DynamicResource MaterialDesignPaper}"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}">
                                    <Grid>
                                        <!-- 无预览图时的占位符 -->
                                        <materialDesign:PackIcon Kind="FileDocumentOutline" 
                                                                 Width="64" Height="64"
                                                                 Opacity="0.3"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalAlignment="Center"/>
                                        <Image Source="{Binding PreviewImageFileName, Converter={StaticResource PreviewPathConverter}}" 
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                </Border>

                                <!-- 选中标记 -->
                                <materialDesign:ColorZone Grid.Row="0" 
                                                          Mode="PrimaryMid" 
                                                          Width="36" Height="36"
                                                          CornerRadius="18"
                                                          Margin="8"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Top"
                                                          Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <materialDesign:ColorZone.Effect>
                                        <DropShadowEffect BlurRadius="6" Opacity="0.5" Direction="0" ShadowDepth="0"/>
                                    </materialDesign:ColorZone.Effect>
                                    <materialDesign:PackIcon Kind="Check" Width="24" Height="24"
                                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </materialDesign:ColorZone>

                                <!-- 时间戳和元数据 -->
                                <StackPanel Grid.Row="1" Margin="0 10 0 0">
                                    <TextBlock Text="{Binding BackupTime, StringFormat=yyyy-MM-dd HH:mm:ss}" 
                                               FontWeight="Bold" 
                                               FontSize="15"
                                               Foreground="{DynamicResource MaterialDesignBody}"/>
                                    <TextBlock Text="{Binding BackupTime, StringFormat='{}备份于 {0:yyyy年MM月dd日 HH:mm}'}" 
                                               FontSize="12" 
                                               Margin="0 2 0 0"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                
                <!-- 无备份时的空状态提示 -->
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.Backups.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"
                                                                         Kind="History" 
                                                                         Width="80" Height="80"
                                                                         Opacity="0.3"
                                                                         Margin="0 0 0 16"/>
                                                <TextBlock Text="暂无备份记录" 
                                                           FontSize="18"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0 8 0 0"/>
                                                <TextBlock Text="当您保存或删除作业时，系统会自动创建备份" 
                                                           FontSize="13"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           MaxWidth="300"
                                                           Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部操作栏 -->
        <Grid Grid.Row="2" Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 右侧操作按钮 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Style="{StaticResource MaterialDesignPaperButton}" 
                        Margin="0 0 8 0"
                        Click="ButtonDeleteSelected_OnClick"
                        IsEnabled="{Binding ViewModel.SelectedBackup, Converter={StaticResource NotNullToBoolConverter}}">
                    <ely:IconText Kind="DeleteOutline" Text="删除选中项"/>
                </Button>
                <Button Margin="0 0 8 0"
                        Click="ButtonRestoreSelected_OnClick"
                        IsEnabled="{Binding ViewModel.SelectedBackup, Converter={StaticResource NotNullToBoolConverter}}">
                    <ely:IconText Kind="Restore" Text="还原选中项"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignPaperButton}" 
                        Margin="0 0 8 0"
                        Click="ButtonCancel_OnClick">
                    <ely:IconText Kind="Close" Text="关闭"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 还原确认对话框 -->
        <materialDesign:DialogHost Grid.Row="0" Grid.RowSpan="3"
                                     Identifier="ConfirmDialog"
                                     IsOpen="{Binding ViewModel.IsConfirmDialogOpen}">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel MinWidth="350" MaxWidth="450" Margin="24">
                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Margin="0 0 0 16"/>
                    
                    <TextBlock Text="确认还原备份" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0 8 0 0"/>
                    
                    <TextBlock TextWrapping="Wrap" 
                               TextAlignment="Center"
                               Margin="0 12 0 0">
                        <Run Text="您确定要还原到 "/>
                        <Run Text="{Binding ViewModel.SelectedBackup.BackupTime, StringFormat=yyyy-MM-dd HH:mm:ss, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" 的备份吗？"/>
                        <LineBreak/>
                        <Run Text="注意：当前所有未保存的更改将会丢失！" 
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0 20 0 0">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Margin="0 0 8 0"
                                Click="ButtonConfirmCancel_OnClick">
                            取消
                        </Button>
                        <Button Click="ButtonConfirmRestore_OnClick">
                            确认还原
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- 删除确认对话框 -->
        <materialDesign:DialogHost Grid.Row="0" Grid.RowSpan="3"
                                     Identifier="DeleteConfirmDialog"
                                     IsOpen="{Binding ViewModel.IsDeleteDialogOpen}">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel MinWidth="350" MaxWidth="450" Margin="24">
                    <materialDesign:PackIcon Kind="DeleteOutline"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                             Margin="0 0 0 16"/>
                    
                    <TextBlock Text="确认删除备份" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0 8 0 0"/>
                    
                    <TextBlock TextWrapping="Wrap" 
                               TextAlignment="Center"
                               Margin="0 12 0 0">
                        <Run Text="您确定要删除备份 "/>
                        <Run Text="{Binding ViewModel.SelectedBackup.BackupTime, StringFormat=yyyy-MM-dd HH:mm:ss, Mode=OneWay}" FontWeight="Bold"/>
                        <Run Text=" 吗？"/>
                        <LineBreak/>
                        <Run Text="此操作不可撤销！" 
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0 20 0 0">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Margin="0 0 8 0"
                                Click="ButtonDeleteCancel_OnClick">
                            取消
                        </Button>
                        <Button Click="ButtonDeleteConfirm_OnClick">
                            确认删除
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- 清空所有备份确认对话框 -->
        <materialDesign:DialogHost Grid.Row="0" Grid.RowSpan="3"
                                     Identifier="ClearAllConfirmDialog"
                                     IsOpen="{Binding ViewModel.IsClearAllDialogOpen}">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel MinWidth="350" MaxWidth="450" Margin="24">
                    <materialDesign:PackIcon Kind="DeleteSweep"
                                             Width="48" Height="48"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                             Margin="0 0 0 16"/>
                    
                    <TextBlock Text="确认清空所有备份" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0 8 0 0"/>
                    
                    <TextBlock TextWrapping="Wrap" 
                               TextAlignment="Center"
                               Margin="0 12 0 0">
                        <Run Text="您确定真的要清空所有的备份吗？"/>
                        <LineBreak/>
                        <Run Text="此操作不可撤销！" 
                           Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0 20 0 0">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                Margin="0 0 8 0"
                                Click="ButtonClearAllCancel_OnClick">
                            取消
                        </Button>
                        <Button Click="ButtonClearAllConfirm_OnClick">
                            确认清空
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>
        </materialDesign:DialogHost>

        <!-- 加载遮罩层 -->
        <Grid Grid.Row="0" Grid.RowSpan="3" 
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              Visibility="{Binding ViewModel.IsWorking, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    Background="{DynamicResource MaterialDesignPaper}"
                    Opacity="0.85"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ely:StarRailLoadingControl/>
                <TextBlock Text="{Binding ViewModel.StatusMessage}" 
                           FontSize="14"
                           Foreground="{DynamicResource MaterialDesignBody}"
                           HorizontalAlignment="Center"
                           Margin="0 12 0 0"/>
            </StackPanel>
        </Grid>
    </Grid>
</ely:MyWindow>